# Database Configuration
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/hoagiang_manager

# JWT Authentication
# Secret key for JWT tokens (minimum 32 characters, use a strong random string in production)
JWT_SECRET=your-secret-key-change-this-min-32-characters
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3000
NODE_ENV=development

# File Upload Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880

# Production-specific settings (uncomment and configure for production)
# NODE_ENV=production
# DATABASE_URL=postgresql://username:password@your-production-db-host:5432/hoagiang_manager
# JWT_SECRET=your-production-secret-key-min-32-characters
# UPLOAD_DIR=/var/www/uploads (or use cloud storage like S3)
